# Cashpile — Web App Environment Variables
# Copy this to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# MiroFish Integration
MIROFISH_URL=https://your-mirofish-service.railway.app
MIROFISH_API_KEY=your-mirofish-api-key
MIROFISH_WEBHOOK_SECRET=your-hmac-shared-secret

# Cron security
CRON_SECRET=your-cron-secret

# RSS Feed URLs (optional — defaults built into feed.service.ts)
# REUTERS_RSS_URL=https://feeds.reuters.com/reuters/businessNews
# YAHOO_FINANCE_RSS_URL=https://finance.yahoo.com/news/rssindex
# INVESTING_RSS_URL=https://www.investing.com/rss/news.rss

# App base URL (for webhook callbacks)
NEXT_PUBLIC_APP_URL=https://your-cashpile-app.railway.app
